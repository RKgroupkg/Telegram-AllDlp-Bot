#!/usr/bin/env bash
# ==================================================
# RKgroupkg - Start Script
# Optimized for Render Free Tier
# ==================================================

# NOTE: No set -euo pipefail here intentionally —
# we handle errors manually so warnings don't kill the script

# ─── Colors ───────────────────────────────────────
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

# ─── Logging ──────────────────────────────────────
log_info()    { echo -e "${BLUE}[INFO]${NC}    $1"; }
log_success() { echo -e "${GREEN}[✓]${NC}      $1"; }
log_warn()    { echo -e "${YELLOW}[⚠]${NC}     $1"; }
log_error()   { echo -e "${RED}[✗]${NC}      $1" >&2; }
log_section() { echo -e "\n${CYAN}${BOLD}── $1 ──${NC}"; }

# ─── Error Handler ────────────────────────────────
error_exit() {
    log_error "$1"
    log_error "Aborting at line ${2:-?}."
    exit 1
}

# ─── PATH Setup ───────────────────────────────────
setup_path() {
    log_section "Environment Setup"

    export DENO_INSTALL="/opt/render/project/src/.deno"

    # Add paths without duplicates
    case ":$PATH:" in
        *":$DENO_INSTALL/bin:"*) ;;
        *) export PATH="$DENO_INSTALL/bin:$PATH" ;;
    esac
    case ":$PATH:" in
        *":$HOME/.local/bin:"*) ;;
        *) export PATH="$HOME/.local/bin:$PATH" ;;
    esac

    log_info "Home     : $HOME"
    log_info "Work Dir : $(pwd)"
    log_info "Deno dir : $DENO_INSTALL/bin"
}

# ─── Deno Setup ───────────────────────────────────
setup_deno() {
    log_section "Deno Setup"

    # Already installed and working
    if [ -x "$DENO_INSTALL/bin/deno" ]; then
        log_success "Deno already installed: $("$DENO_INSTALL/bin/deno" --version 2>&1 | head -1)"
        return 0
    fi

    log_info "Deno not found — installing now..."
    mkdir -p "$DENO_INSTALL/bin"

    # Try unzip method first (faster)
    if command -v unzip &> /dev/null; then
        log_info "Downloading Deno binary..."
        curl -fsSL https://github.com/denoland/deno/releases/latest/download/deno-x86_64-unknown-linux-gnu.zip \
            -o "$DENO_INSTALL/deno.zip" 2>&1

        if [ $? -eq 0 ]; then
            unzip -o "$DENO_INSTALL/deno.zip" -d "$DENO_INSTALL/bin/" 2>&1
            chmod +x "$DENO_INSTALL/bin/deno"
            rm -f "$DENO_INSTALL/deno.zip"
        else
            log_warn "Direct download failed — trying install script fallback..."
            curl -fsSL https://deno.land/install.sh | DENO_INSTALL="$DENO_INSTALL" sh 2>&1
        fi
    else
        # Fallback to install script
        log_info "unzip not available — using Deno install script..."
        curl -fsSL https://deno.land/install.sh | DENO_INSTALL="$DENO_INSTALL" sh 2>&1
    fi

    # Final verify
    if [ -x "$DENO_INSTALL/bin/deno" ]; then
        log_success "Deno installed: $("$DENO_INSTALL/bin/deno" --version 2>&1 | head -1)"
    else
        log_warn "Deno install failed — YouTube n-challenge will fail"
        log_warn "Bot will still start but YouTube downloads may be broken"
    fi
}

# ─── OS Check ─────────────────────────────────────
check_os() {
    log_section "OS Check"
    case "$OSTYPE" in
        msys|win32|cygwin)
            error_exit "Windows is not supported." "$LINENO" ;;
        linux*)
            log_success "OS: Linux" ;;
        darwin*)
            log_success "OS: macOS" ;;
        *)
            log_warn "Unknown OS: $OSTYPE — proceeding anyway." ;;
    esac
}

# ─── Python Check ─────────────────────────────────
check_python() {
    log_section "Python Check"

    if ! command -v python3 &> /dev/null; then
        error_exit "Python 3 is not installed." "$LINENO"
    fi

    PYTHON_VERSION=$(python3 --version 2>&1 | cut -d' ' -f2)
    MAJOR=$(echo "$PYTHON_VERSION" | cut -d. -f1)
    MINOR=$(echo "$PYTHON_VERSION" | cut -d. -f2)

    if [[ "$MAJOR" -lt 3 || ("$MAJOR" -eq 3 && "$MINOR" -lt 8) ]]; then
        error_exit "Python $PYTHON_VERSION is too old. Requires 3.8+." "$LINENO"
    fi

    log_success "Python $PYTHON_VERSION"
}

# ─── Tools Check ──────────────────────────────────
check_tools() {
    log_section "Tools Check"
    local critical_ok=true
    # deno — should be set up by now
    if [ -x "$DENO_INSTALL/bin/deno" ]; then
        log_success "deno    : $("$DENO_INSTALL/bin/deno" --version 2>&1 | head -1)"
    else
        log_warn "deno    : NOT FOUND — YouTube n-challenge will fail"
    fi

    # ffmpeg — warning only
    if command -v ffmpeg &> /dev/null; then
        log_success "ffmpeg  : $(ffmpeg -version 2>&1 | head -1 | cut -d' ' -f1-3)"
    else
        log_warn "ffmpeg  : NOT FOUND — audio/video merging may fail"
    fi

    # telegram client library
    if python3 -c "import telethon" &> /dev/null 2>&1; then
        log_success "telegram: telethon found"
    elif python3 -c "import pyrogram" &> /dev/null 2>&1; then
        log_success "telegram: pyrogram found"
    else
        log_warn "telegram: no client library found (telethon/pyrogram)"
    fi

    if [ "$critical_ok" = false ]; then
        error_exit "Critical tools missing. Aborting." "$LINENO"
    fi
}

# ─── Run Bot ──────────────────────────────────────
run_bot() {
    log_section "Starting Bot"
    log_info "Launching: python3 -m src"
    echo ""

    export PATH
    export DENO_INSTALL

    python3 -m src
    EXIT_CODE=$?

    if [ $EXIT_CODE -ne 0 ]; then
        error_exit "Bot exited with code $EXIT_CODE. Check logs above." "$LINENO"
    fi
}

# ─── Main ─────────────────────────────────────────
main() {
    echo -e "${CYAN}${BOLD}"
    echo "╔═══════════════════════════════════════╗"
    echo "║     RKgroupkg — Quick DL Bot          ║"
    echo "║     Render Free Tier Start Script     ║"
    echo "╚═══════════════════════════════════════╝"
    echo -e "${NC}"

    setup_path
    setup_deno    # ← installs deno fresh every start if missing
    check_os
    check_python
    check_tools
    run_bot
}

main
