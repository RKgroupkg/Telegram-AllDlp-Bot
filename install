#!/bin/bash
# ==================================================
# RKgroupkg - Install Script (yt-dlp + Deno Support)
# ==================================================

# Color codes
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

# ---------- Functions ---------- #

install_pip() {
    echo -e "${YELLOW}Checking for pip...${NC}"
    if command -v pip3 &> /dev/null; then
        echo -e "${GREEN}Pip is already installed.${NC}"
        return 0
    fi
    echo -e "${YELLOW}Installing pip...${NC}"
    if command -v apt-get &> /dev/null; then
        sudo apt-get update
        sudo apt-get install -y python3-pip
    elif command -v yum &> /dev/null; then
        sudo yum install -y python3-pip
    elif command -v brew &> /dev/null; then
        brew install python
    else
        echo -e "${RED}Unsupported package manager.${NC}"
        return 1
    fi
    command -v pip3 &> /dev/null && echo -e "${GREEN}Pip installed successfully.${NC}" || {
        echo -e "${RED}Failed to install pip.${NC}"
        return 1
    }
}

install_requirements() {
    echo -e "${YELLOW}Installing requirements...${NC}"
    if [ ! -f "requirements.txt" ]; then
        echo -e "${RED}requirements.txt not found.${NC}"
        return 1
    fi
    # Upgrade pip before install
    pip3 install --upgrade pip
    pip3 install -r requirements.txt
    [ $? -eq 0 ] && echo -e "${GREEN}Requirements installed.${NC}" || {
        echo -e "${RED}Failed to install requirements.${NC}"
        return 1
    }
}

install_ffmpeg() {
    echo -e "${YELLOW}Installing FFmpeg...${NC}"
    if command -v apt-get &> /dev/null; then
        sudo apt-get update
        sudo apt-get install -y ffmpeg
    elif command -v yum &> /dev/null; then
        sudo yum install -y ffmpeg
    elif command -v brew &> /dev/null; then
        brew install ffmpeg
    else
        echo -e "${RED}Unsupported package manager.${NC}"
        return 1
    fi
    command -v ffmpeg &> /dev/null && echo -e "${GREEN}FFmpeg installed successfully.${NC}" || {
        echo -e "${RED}Failed to install FFmpeg.${NC}"
        return 1
    }
}

# ---------- NEW SECTION ---------- #
install_deno() {
    echo -e "${YELLOW}Installing Deno (fresh install for Render free tier)...${NC}"
    curl -fsSL https://deno.land/install.sh | sh
    export DENO_INSTALL="$HOME/.deno"
    export PATH="$DENO_INSTALL/bin:$PATH"

    if command -v deno &> /dev/null; then
        echo -e "${GREEN}✓ Deno installed: $(deno --version | head -1)${NC}"
        return 0
    else
        echo -e "${RED}✗ Deno install failed. PATH: $PATH${NC}"
        ls "$HOME/.deno/bin/" 2>/dev/null || echo -e "${RED}Deno bin dir missing.${NC}"
        return 1
    fi
}

move_cookie_files() {
    echo -e "${YELLOW}Checking and moving cookie files...${NC}"
    mkdir -p cookies
    find . -maxdepth 1 -type f \( -name "cookie_*.txt" -o -name "cookies_*.txt" \) | while read -r file; do
        mv "$file" cookies/
        echo -e "${GREEN}Moved:${NC} $file → cookies/"
    done
}

# ---------- MAIN ---------- #
main() {
    echo -e "${YELLOW}Starting installation process...${NC}"

    install_pip || exit 1
    install_deno || echo -e "${YELLOW}⚠️ Warning: Deno not installed, yt-dlp may fail for YouTube.${NC}"
    install_requirements || exit 1
    install_ffmpeg || exit 1

    echo -e "${GREEN}Installation completed successfully!${NC}"
    move_cookie_files
}

main
